    {
      "parameters": {
        "javaScriptCode": "const supabaseUrl = 'https://ekarbxdoaoqrtlmfzgyj.supabase.co';\nconst supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVrYXJieGRvYW9xcnRsbWZ6Z3lqIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MTYzNDk1OSwiZXhwIjoyMDk3MjEwOTU5fQ.KV9rv7Q0RNs1g3jKtWaf3UAh3K2cp-CvujeKWdAoySM';\n\nconst records = $json.records;\nif (!records || records.length === 0) {\n  return { error: 'No poliza found' };\n}\n\nconst poliza = records[0];\nconst today = new Date().toISOString().split('T')[0];\nconst payload = {\n  poliza_id: poliza.id,\n  asegurado: String(poliza.cliente_id || ''),\n  fecha_ocurrencia: today,\n  descripcion: $json.descripcion,\n  estado: 'avisado'\n};\n\nconst url = `${supabaseUrl}/rest/v1/siniestros`;\nconst response = await fetch(url, {\n  method: 'POST',\n  headers: {\n    'Authorization': `Bearer ${supabaseKey}`,\n    'Content-Type': 'application/json',\n    'apikey': supabaseKey,\n    'Prefer': 'return=representation'\n  },\n  body: JSON.stringify(payload)\n});\n\nconst data = response.ok ? await response.json() : { error: await response.text() };\nreturn data;"
      },
