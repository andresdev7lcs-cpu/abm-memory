        "javaScriptCode": "const polizaId = $json.poliza_id;\nconst supabaseUrl = 'https://ekarbxdoaoqrtlmfzgyj.supabase.co';\nconst supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVrYXJieGRvYW9xcnRsbWZ6Z3lqIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MTYzNDk1OSwiZXhwIjoyMDk3MjEwOTU5fQ.KV9rv7Q0RNs1g3jKtWaf3UAh3K2cp-CvujeKWdAoySM';\n\nconst url = `${supabaseUrl}/rest/v1/polizas?numero=eq.${polizaId}`;\nconst response = await fetch(url, {\n  method: 'GET',\n  headers: {\n    'Authorization': `Bearer ${supabaseKey}`,\n    'Content-Type': 'application/json',\n    'apikey': supabaseKey\n  }\n});\n\nconst data = response.ok ? await response.json() : [];\nreturn { records: data };"
